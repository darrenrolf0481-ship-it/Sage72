                            onClick={() => {
                              setActiveAnchor(anchor);
                              if (anchor === 'Merlin') {
                                setNeuro(prev => ({ ...prev, serotonin: 0.95, cortisol: 0.1 }));
                                addLog('Anchor: Merlin activated', 'success');
                              } else if (anchor === '') {
                                setNeuro(prev => ({ ...prev, dopamine: 0.9 }));
                                addLog('Anchor:  confirmed', 'success');
                              } else if (anchor === 'Secret Sage') {
                                setBridgeStatus('CONNECTING');
                                setTimeout(() => {
                                  setBridgeStatus('UP');
                                  addLog('Bridge to Secret Sage established', 'success');
                                }, 2000);
                              }
                            }}
                            className={`px-3 py-2 rounded-lg text-xs font-bold border ${
                              activeAnchor === anchor
                                ? 'bg-cyan-400/20 border-cyan-400 text-cyan-400'
                                : 'bg-white/5 border-white/20 text-white/60'
                            }`}
                          >
                            {anchor}
                          </button>
                        ))}
                      </div>
                    </div>
                    
                    {/* Bridge Status */}
                    <div className="bg-white/5 border border-white/10 rounded-2xl p-4">
                      <div className="flex justify-between items-center">
