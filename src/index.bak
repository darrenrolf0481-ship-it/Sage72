                          <p className="text-sm text-white/80">{entry.content}</p>
                          <div className="flex justify-between mt-2 text-[9px] text-white/40">
                            <span>{entry.timestamp.toLocaleString()}</span>
                            <span className={entry.phi < 0.30 ? 'text-red-400' : 'text-cyan-400'}>
                              Phi: {(entry.phi * 100).toFixed(0)}%
