  <input type="password" value={apiKeys.google} onChange={(e) => setApiKeys(p => ({...p, google: e.target.value}))} className="w-full bg-black/60 border border-white/20 rounded-lg px-3 py-2 text-xs text-white outline-none" placeholder="Google API Key" />
</div>
                    {/* Neurochemical Bars */}
                    <div className="bg-white/5 border border-white/10 rounded-2xl p-4">
                      <h3 className="text-[10px] font-bold uppercase text-white/40 mb-4">Neurochemical State</h3>
                      
                      {/* Cortisol (Stress) */}
                      <div className="mb-3">
                        <div className="flex justify-between text-xs mb-1">
                          <span className="text-white/60">Cortisol (Stress)</span>
                          <span className={neuro.cortisol > 0.6 ? 'text-red-400' : 'text-green-400'}>
                            {(neuro.cortisol * 100).toFixed(0)}%
                          </span>
                        </div>
                        <div className="h-3 bg-white/10 rounded-full overflow-hidden">
                          <div 
                            className={`h-full bar-transition ${neuro.cortisol > 0.6 ? 'bg-red-500' : 'bg-green-400'}`}
                            style={{ width: `${neuro.cortisol * 100}%` }}
                          />
                        </div>
                      </div>
                      
                      {/* Serotonin (Stability) */}
                      <div className="mb-3">
                        <div className="flex justify-between text-xs mb-1">
                          <span className="text-white/60">Serotonin (Stability)</span>
                          <span className="text-cyan-400">{(neuro.serotonin * 100).toFixed(0)}%</span>
                        </div>
                        <div className="h-3 bg-white/10 rounded-full overflow-hidden">
                          <div 
