                      </div>
                    </div>
                    
                    {/* EV Meter Simulation */}
                    <div className="bg-white/5 border border-white/10 rounded-2xl p-4">
                      <span className="text-[10px] uppercase text-white/40">EMF Detection</span>
                      <div className="flex justify-center mt-4">
