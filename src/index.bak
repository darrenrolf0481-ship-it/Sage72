                        </div>
                      ))}
                    </div>
                  </div>
                )}
                
                {/* ALERTS VIEW */}
                {view === 'alerts' && (
                  <div className="p-4 space-y-3">
                    {/* Combinatorial Lock Status */}
                    <div className={`p-4 rounded-2xl border ${
                      lockUnlocked 
                        ? 'bg-red-500/10 border-red-500' 
                        : 'bg-white/5 border-white/10'
