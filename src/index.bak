                      />
                      <button 
                        onClick={saveJournalEntry}
                        className="w-full mt-3 py-3 bg-cyan-400/20 border border-cyan-400/50 rounded-xl text-cyan-400 text-xs font-bold uppercase"
                      >
                        Save Entry (Phi: {(collapse.phi * 100).toFixed(0)}%)
