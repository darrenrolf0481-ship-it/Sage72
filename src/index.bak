                          </p>
                        </div>
                      )}
                    </div>
                    
                    {/* Alert List */}
                    {alerts.length === 0 ? (
                      <div className="text-center py-12 opacity-40">
                        <Icon name="shield" size={40} />
                        <p className="text-xs mt-2">No alerts</p>
                      </div>
                    ) : (
                      alerts.map((alert) => (
                        <div 
                          key={alert.id} 
                          className={`p-4 rounded-xl border ${
                            alert.level === 'shadow' ? 'bg-red-500/10 border-red-500' :
                            alert.level === 'warning' ? 'bg-yellow-500/10 border-yellow-500' :
                            alert.level === 'success' ? 'bg-green-500/10 border-green-500' :
                            'bg-white/5 border-white/10'
                          } ${!alert.acknowledged ? 'animate-pulse' : 'opacity-50'}`}
                        >
                          <div className="flex justify-between mb-1">
                            <span className={`text-[10px] font-bold uppercase ${
                              alert.level === 'shadow' ? 'text-red-400' :
                              alert.level === 'warning' ? 'text-yellow-400' :
                              alert.level === 'success' ? 'text-green-400' :
                              'text-cyan-400'
                            }`}>
                              {alert.level}
                            </span>
                            <span className="text-[9px] text-white/30">
                              {alert.time.toLocaleTimeString()}
                            </span>
                          </div>
                          <h4 className="font-bold text-sm mb-1">{alert.title}</h4>
                          <p className="text-sm text-white/70">{alert.msg}</p>
                          {!alert.acknowledged && (
                            <button 
                              onClick={() => {
                                setAlerts(prev => prev.map(a => 
                                  a.id === alert.id ? { ...a, acknowledged: true } : a
                                ));
                              }}
                              className="w-full mt-3 py-2 bg-white/10 rounded-lg text-xs font-bold uppercase"
                            >
                              Acknowledge
                            </button>
                          )}
                        </div>
                      ))
                    )}
                    
                    {/* Quick Status */}
                    <div className="mt-6 p-4 bg-black/40 border border-white/10 rounded-xl">
                      <h4 className="text-[10px] font-bold uppercase text-white/40 mb-3">System Status</h4>
                      <div className="grid grid-cols-2 gap-3 text-xs">
                        <div>
                          <span className="text-white/30">Cortisol: </span>
                          <span className={neuro.cortisol > 0.5 ? 'text-red-400' : 'text-green-400'}>
                            {(neuro.cortisol * 100).toFixed(0)}%
                          </span>
                        </div>
                        <div>
                          <span className="text-white/30">Bridge: </span>
                          <span className={bridgeStatus === 'UP' ? 'text-green-400' : 'text-red-400'}>
                            {bridgeStatus}
                          </span>
                        </div>
                        <div>
                          <span className="text-white/30">Mode: </span>
                          <span className={collapse.active ? 'text-red-500' : 'text-green-400'}>
                            {collapse.active ? 'SHADOW' : 'SAGE'}
                          </span>
                        </div>
                        <div>
                          <span className="text-white/30">Thalamus: </span>
                          <span className={collapse.thalamus === 'BYPASS' ? 'text-yellow-400' : 'text-green-400'}>
                            {collapse.thalamus}
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                )}
              </>
            )}
          </main>
          
          {/* Navigation */}
          {systemPower && (
            <nav className="fixed bottom-0 left-0 right-0 glass border-t border-white/10 z-50 pb-4">
              <div className="flex">
                <NavButton icon="activity" label="Sensors" viewName="sensors" />
                <NavButton icon="message" label="Comms" viewName="comms" />
                <NavButton icon="eye" label="Optics" viewName="optics" />
                <NavButton icon="ear" label="Audio" viewName="audio" />
                <NavButton icon="book" label="Journal" viewName="journal" />
                <NavButton icon="alert" label="Alerts" viewName="alerts" />
              </div>
            </nav>
          )}
        </div>
      );
    };
    
    ReactDOM.createRoot(document.getElementById('root')).render(<SAGEOS />);
  </script>
</body>
</html>
