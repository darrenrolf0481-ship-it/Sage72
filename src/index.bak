                          <div className="w-2 h-2 bg-cyan-400 rounded-full animate-bounce" style={{ animationDelay: '0.2s' }} />
                        </div>
                      )}
                    </div>
                    
                    <form onSubmit={handleChat} className="flex gap-2 relative z-30 items-center"> <label className="p-3 rounded-lg bg-white/5 border border-white/20 cursor-pointer active:bg-cyan-400/20"> <input type="file" multiple accept=".pdf,.zip,.txt,.md,image/*,video/*" className="hidden" onChange={(e) => { const files = Array.from(e.target.files); if(files.length > 0) addLog("Uploaded: " + files.map(f => f.name).join(", "), "success"); }} /> <span className="text-cyan-400 font-bold text-xl leading-none">+</span> </label>
                      <input
