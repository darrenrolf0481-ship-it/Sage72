                        className={`p-3 rounded-lg ${
                          collapse.active 
                            ? 'bg-red-500/20 border border-red-500/50' 
                            : 'bg-cyan-400/20 border border-cyan-400/50'
                        }`}
                      >
                        <Icon name="send" size={18} color={collapse.active ? SAGE_RED : SAGE_CYAN} />
                      </button>
                    </form>
                  </div>
